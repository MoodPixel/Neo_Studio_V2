{
  "schema_id": "neo.models.folder_rules.v1",
  "version": "0.7.0-curated-base-model-guide",
  "policy": "Folder rules map backend + model_type to target subfolders. User root paths are configured later in neo_data and are not stored in the repo.",
  "backends": {
    "comfyui": {
      "checkpoint": "models/checkpoints",
      "lora": "models/loras",
      "vae": "models/vae",
      "clip": "models/clip",
      "text_encoder": "models/text_encoders",
      "controlnet": "models/controlnet",
      "ipadapter": "models/ipadapter",
      "upscaler": "models/upscale_models",
      "unet": "models/unet",
      "unet_gguf": "models/unet",
      "embedding": "models/embeddings",
      "face_model": "models/facerestore_models",
      "diffusion_model": "models/diffusion_models",
      "video_diffusion": "models/diffusion_models",
      "video_gguf": "models/diffusion_models",
      "audio_encoder": "models/audio_encoders",
      "clip_vision": "models/clip_vision",
      "faceid": "models/ipadapter",
      "faceid_lora": "models/loras",
      "pose_detection": "models/detection",
      "detection": "models/detection",
      "model_patch": "models/diffusion_models"
    },
    "forge": {
      "checkpoint": "models/Stable-diffusion",
      "lora": "models/Lora",
      "vae": "models/VAE",
      "embedding": "embeddings"
    },
    "koboldcpp": {
      "llm_gguf": "{user_llm_models_root}",
      "llm_mmproj": "{user_llm_models_root}",
      "llm_transformers": "{user_llm_models_root}"
    },
    "local_llm": {
      "llm_gguf": "{user_llm_models_root}",
      "embedding": "{user_embedding_models_root}",
      "reranker": "{user_reranker_models_root}",
      "llm_mmproj": "{user_llm_models_root}",
      "llm_transformers": "{user_llm_models_root}"
    }
  },
  "allowed_extensions": {
