{
  "id": "image.high_res_lab",
  "name": "Image · High-Res Lab",
  "version": "0.9.1",
  "description": "Built-in Image Finish extension for route-profiled high-resolution refinement, aspect-safe resizing, selected-output source refinement, and replay-safe output metadata.",
  "extension_type": "workflow_extension",
  "extension_origin": "built_in",
  "surface": "image",
  "subtabs": [
    "finish"
  ],
  "workflow_modes": [
    "generate",
    "img2img",
    "inpaint",
    "outpaint"
  ],
  "workspace_apps": [
    "finish"
  ],
  "mount_slots": [
    "image.finish.high_res_lab"
  ],
  "mount_targets": [
    {
      "surface": "image",
      "workspace_app": "finish",
      "workflow_mode": null,
      "slot": "image.finish.high_res_lab",
      "route_states": [
        "available",
        "experimental_available"
      ]
    }
  ],
  "supported_backends": [
    "comfyui"
  ],
  "supported_families": [
    "sdxl",
    "sd15",
    "flux",
    "flux2_klein",
    "qwen_image",
    "qwen_image_edit_2509",
    "qwen_rapid_aio",
    "z_image",
    "z_image_turbo",
    "hidream"
  ],
  "supported_loaders": [
    "checkpoint",
    "checkpoint_aio",
    "diffusion_model",
    "gguf"
  ],
  "depends_on": [],
  "extends": [],
  "required_nodes": {
    "comfyui": [
      "KSampler",
      "LatentUpscale",
      "ImageScale",
      "VAEEncode",
      "VAEDecode"
    ],
    "comfyui_portable": [
      "KSampler",
      "LatentUpscale",
      "ImageScale",
      "VAEEncode",
      "VAEDecode"
    ]
  },
  "node_requirements": {
    "decision": "graph_based_not_custom_node_required",
    "base_required_concepts": [
      "sampler anchor",
      "latent or image upscale path",
      "VAE encode/decode path",
      "final output reroute point"
    ],
    "required_base_nodes": [
      "KSampler",
      "LatentUpscale",
      "ImageScale",
      "VAEEncode",
      "VAEDecode"
    ],
    "optional_nodes": [
      "VAEDecodeTiled",
      "UpscaleModelLoader",
      "ImageUpscaleWithModel",
      "UltimateSDUpscale",
      "ControlNetLoader",
      "ControlNetApply"
    ],
    "missing_optional_policy": "Gate only the optional control/path. Do not gate the full extension when optional enhancement nodes are missing.",
    "phase_e_runtime_policy": "Skeleton only. Required node detection is declared but not executed until validation/workflow phases.",
    "phase_i_runtime_policy": "Validation hooks inspect required base nodes and optional enhancement nodes. Missing required nodes provider-gate the extension; missing optional nodes only gate optional controls/paths.",
    "phase_k_runtime_policy": "Optional node discovery now reports per-path availability for VAEDecodeTiled, model-upscale nodes, Ultimate SD Upscale, and ControlNet preserve hints. Missing optional nodes gate only matching controls/paths.",
    "optional_node_groups": {
      "tiled_vae_decode": [
        "VAEDecodeTiled"
      ],
      "model_upscale": [
        "UpscaleModelLoader",
        "ImageUpscaleWithModel"
      ],
      "ultimate_sd_upscale": [
        "UltimateSDUpscale"
      ],
      "controlnet_preserve_hint": [
        "ControlNetLoader",
        "ControlNetApply"
      ]
    },
    "phase_p7_runtime_policy": "P7 resolves target size from selected preview source, route dimensions, or latent dimensions; preview-action High-Res Lab starts from the selected LoadImage instead of a fresh base KSampler; image_upscale uses Forge-like upscale -> VAEEncode -> diffusion refine unless strategy=upscale_only.",
    "phase_p8_0_route_profile_policy": "High-Res Lab now derives extension availability from route profiles synced to the base route matrix; base route availability is necessary but not sufficient.",
    "phase_p8_1_flux_policy": "P8.1 promotes Flux 1 Safetensors / Components and Flux 1 GGUF High-Res Lab profiles. Flux uses pixel refine, latent refine, and upscale-only; SD-style Ultimate SD Upscale and High-Res CFG override are blocked for Flux.",
    "phase_p8_2_qwen_policy": "P8.2 promotes Qwen Image Edit, Qwen Rapid AIO, and Qwen Image Edit 2509 High-Res Lab profiles across safetensors/checkpoint AIO/GGUF; Qwen blocks Ultimate SD Upscale and clamps refine CFG safely.",
    "phase_p8_3_flux_klein_policy": "P8.3 promotes Flux Klein Safetensors / Components and Flux Klein GGUF High-Res Lab profiles. Klein uses pixel refine, latent refine, and upscale-only; SD-style Ultimate SD Upscale and High-Res CFG override are blocked for Flux Klein.",
    "phase_p8_4_zimage_policy": "P8.4 promotes ZImage Safetensors / Components and ZImage GGUF High-Res Lab profiles. ZImage uses pixel refine, latent refine, and upscale-only; SD-style Ultimate SD Upscale and Qwen re-edit are blocked for ZImage.",
    "phase_p8_5_zimage_turbo_policy": "P8.5 promotes ZImage Turbo Safetensors / Components and GGUF High-Res Lab profiles. Turbo uses conservative low-step/low-CFG pixel refine, latent refine, and upscale-only; SD-style Ultimate SD Upscale and Qwen re-edit are blocked."
  },
