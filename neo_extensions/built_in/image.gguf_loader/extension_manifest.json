{
  "id": "image.gguf_loader",
  "name": "GGUF Loader Support",
  "version": "0.2.0",
  "description": "Declares backend-neutral GGUF loader capability profiles for supported image model families without placing GGUF workflow logic inside the base Image surface.",
  "extension_type": "loader_extension",
  "surface": "image",
  "subtabs": [
    "generate",
    "img2img",
    "edit",
    "outpaint"
  ],
  "mount_slots": [
    "image.generate.model_loader.after",
    "image.img2img.model_loader.after",
    "image.edit.model_loader.after",
    "image.outpaint.model_loader.after",
    "image.parameters.family_loader.after"
  ],
  "supported_backends": [
    "comfyui",
    "comfyui_portable"
  ],
  "supported_families": [
    "flux",
    "qwen_image",
    "qwen_image_edit_2509",
    "qwen_rapid_aio",
    "z_image",
    "z_image_turbo",
    "wan_image",
    "hunyuan_image",
    "hidream"
  ],
  "supported_loaders": [
    "gguf"
  ],
  "depends_on": [],
  "extends": [],
  "required_nodes": {
    "comfyui": [
      "UnetLoaderGGUF",
      "LoaderGGUF",
      "CLIPLoaderGGUF",
      "ClipLoaderGGUF",
      "DualCLIPLoaderGGUF"
    ],
    "comfyui_portable": [
      "UnetLoaderGGUF",
      "LoaderGGUF",
      "CLIPLoaderGGUF",
      "ClipLoaderGGUF",
      "DualCLIPLoaderGGUF"
    ]
  },
  "capability_profiles": {
    "flux_gguf": {
      "profile_id": "flux_gguf",
      "family": "flux",
      "loader": "gguf",
      "modes": {
        "generate": "native",
        "img2img": "native",
        "edit": "variant_required",
        "outpaint": "experimental"
      },
      "required_roles": [
        "gguf_unet",
        "gguf_text_encoder_primary",
        "gguf_text_encoder_secondary",
        "vae_or_ae",
        "flux_guidance"
      ],
      "optional_roles": [
        "gguf_vae"
      ],
      "readiness_gates": {
        "generate": [
          "gguf_unet",
          "gguf_text_encoder_primary",
          "gguf_text_encoder_secondary",
          "flux_guidance"
        ],
        "img2img": [
          "source_image",
          "gguf_unet",
          "gguf_text_encoder_primary",
          "gguf_text_encoder_secondary",
          "flux_guidance"
        ],
        "outpaint": [
          "source_image",
          "outpaint_padding",
          "gguf_unet",
          "gguf_text_encoder_primary",
          "gguf_text_encoder_secondary",
          "flux_guidance"
        ]
      },
      "params": [
        "gguf_model",
        "text_encoder_1",
        "text_encoder_2",
        "vae",
        "flux_guidance"
      ],
      "backend_requirements": {
        "comfyui": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary",
            "gguf_text_encoder_secondary",
            "flux_guidance"
          ]
        },
        "comfyui_portable": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary",
            "gguf_text_encoder_secondary",
            "flux_guidance"
          ]
        }
      },
      "notes": [
        "Comfy node names are diagnostics; provider compiler selects backend nodes later.",
        "Outpaint remains experimental until Phase 12.14/12.19 routes are implemented."
      ]
    },
    "qwen_image_gguf": {
      "profile_id": "qwen_image_gguf",
      "family": "qwen_image",
      "loader": "gguf",
      "modes": {
        "generate": "native",
        "img2img": "mmproj_required",
        "edit": "mmproj_required",
        "outpaint": "mmproj_required",
        "inpaint": "mmproj_required"
      },
      "required_roles": [
        "gguf_unet",
        "gguf_text_encoder_primary",
        "vae_or_ae"
      ],
      "optional_roles": [
        "qwen_mmproj",
        "gguf_vae"
      ],
      "readiness_gates": {
        "generate": [
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "img2img": [
          "source_image",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "edit": [
          "source_image",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "outpaint": [
          "source_image",
          "outpaint_padding",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "inpaint": [
          "source_image",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ]
      },
      "params": [
        "gguf_model",
        "qwen_text_encoder",
        "qwen_mmproj",
        "vae",
        "route_readiness"
      ],
      "backend_requirements": {
        "comfyui": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary"
          ]
        },
        "comfyui_portable": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary"
          ]
        }
      },
      "notes": [
        "Qwen txt2img must not require mmproj.",
        "Qwen img2img/inpaint/edit/outpaint must require mmproj.",
        "Qwen GGUF must not fallback to Flux routing."
      ]
    },
    "z_image_gguf": {
      "profile_id": "z_image_gguf",
      "family": "z_image",
      "loader": "gguf",
      "modes": {
        "generate": "native",
        "img2img": "provider_gated",
        "edit": "provider_gated",
        "outpaint": "provider_gated"
      },
      "required_roles": [
        "gguf_unet",
        "gguf_text_encoder_primary",
        "vae_or_ae"
      ],
      "optional_roles": [
        "gguf_vae"
      ],
      "readiness_gates": {
        "generate": [
          "gguf_unet",
          "gguf_text_encoder_primary"
        ]
      },
      "params": [
        "gguf_model",
        "qwen3_text_encoder",
        "vae",
        "turbo_mode"
      ],
      "backend_requirements": {
        "comfyui": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary"
          ]
        },
        "comfyui_portable": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary"
          ]
        }
      },
      "notes": [
        "Only txt2img/generate is declared native for the first Z-Image GGUF foundation."
      ]
    },
    "wan_image_gguf": {
      "profile_id": "wan_image_gguf",
      "family": "wan_image",
      "loader": "gguf",
      "modes": {
        "generate": "provider_gated",
        "img2img": "provider_gated",
        "inpaint": "provider_gated",
        "outpaint": "provider_gated",
        "edit": "unsupported"
      },
      "required_roles": [
        "gguf_unet"
      ],
      "optional_roles": [
        "umt5_text_encoder",
        "wan_vae",
        "wan_task"
      ],
      "readiness_gates": {
        "generate": [
          "provider_route"
        ],
        "img2img": [
          "provider_route"
        ],
        "inpaint": [
          "provider_route"
        ],
        "outpaint": [
          "provider_route"
        ]
      },
      "params": [
        "gguf_model",
        "umt5_text_encoder",
        "wan_vae",
        "wan_task",
        "provider_status"
      ],
      "backend_requirements": {
        "comfyui": {
          "required_roles": [
            "gguf_unet"
          ]
        },
        "comfyui_portable": {
          "required_roles": [
            "gguf_unet"
          ]
        }
      },
      "notes": [
        "Phase 12.17 keeps Wan Image modes provider-gated in the Image surface.",
        "No txt2img/img2img/inpaint/outpaint compiler is enabled until a confirmed image workflow exists.",
        "Wan video/image-to-video workflows belong behind explicit provider/video routes, not SDXL-style Image-tab assumptions."
      ]
    },
    "hunyuan_image_gguf": {
      "profile_id": "hunyuan_image_gguf",
      "family": "hunyuan_image",
      "loader": "gguf",
      "modes": {
        "generate": "provider_gated",
        "img2img": "provider_gated",
        "inpaint": "provider_gated",
        "outpaint": "provider_gated"
      },
      "required_roles": [
        "gguf_unet"
      ],
      "optional_roles": [
        "hunyuan_variant",
        "text_encoder_primary",
        "vae_or_ae"
      ],
      "readiness_gates": {},
      "params": [
        "gguf_model",
        "hunyuan_variant",
        "provider_status"
      ],
      "backend_requirements": {
        "comfyui": {
          "required_roles": [
            "gguf_unet"
          ]
        },
        "comfyui_portable": {
          "required_roles": [
            "gguf_unet"
          ]
        }
      },
      "notes": [
        "Phase 12.18: Hunyuan remains provider-gated until the exact branch/workflow compiler is selected."
