        "comfyui": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary"
          ]
        },
        "comfyui_portable": {
          "required_roles": [
            "gguf_unet",
            "gguf_text_encoder_primary"
          ]
        }
      },
      "notes": [
        "Qwen txt2img must not require mmproj.",
        "Qwen img2img/inpaint/edit/outpaint must require mmproj.",
        "Qwen GGUF must not fallback to Flux routing.",
        "V25.9.20 Pass E: visible Qwen Rapid AIO family uses the same Qwen single-encoder GGUF runtime shape; this is Neo route support, not a global official-file claim."
      ]
    }
  },
  "ui_schema": {
    "profile_selector": "family_loader_mode",
    "fields": [
      {
        "id": "gguf_model",
        "label": "GGUF Model",
        "help_text": "Select the GGUF model file for the active family.",
        "expert_text": "Mapped to loader=gguf and resolved by backend capability roles."
      },
      {
        "id": "text_encoder_1",
        "label": "Primary Text Encoder",
        "help_text": "Primary encoder role used by Flux/Qwen/Z-Image GGUF profiles."
      },
      {
        "id": "text_encoder_2",
        "label": "Secondary Text Encoder",
        "help_text": "Secondary encoder role required by Flux GGUF."
      },
      {
        "id": "qwen_mmproj",
        "label": "Qwen MMProj",
        "help_text": "Required for Qwen image-conditioned routes: img2img, edit/inpaint, and outpaint."
      },
      {
        "id": "flux_guidance",
        "label": "Flux Guidance",
        "help_text": "Required by Flux GGUF routes."
      },
      {
        "id": "route_readiness",
        "label": "Route Readiness",
        "help_text": "Shows profile blockers from capability discovery and mode gates."
      }
    ]
  },
  "memory_policy": {
    "record_events": [
      "extension.enabled",
      "extension.compatibility_checked",
      "capability.profile.selected",
      "job.compiled"
    ]
  },
  "output_policy": {
    "write_loader_metadata": true,
    "write_capability_profile": true,
    "write_readiness_snapshot": true
  },
  "extension_origin": "built_in",
  "workflow_modes": [
    "generate",
    "img2img",
    "inpaint",
    "outpaint"
  ],
  "workspace_apps": [
    "generations",
    "reference"
  ],
  "mount_targets": [
    {
      "surface": "image",
      "workflow_mode": "generate",
      "workspace_app": "generations",
      "slot": "image.generate.model_loader.after",
      "route_states": [
        "available",
        "experimental_available"
      ]
    },
    {
      "surface": "image",
      "workflow_mode": "img2img",
      "workspace_app": "reference",
      "slot": "image.img2img.model_loader.after",
      "route_states": [
        "available",
        "experimental_available"
      ]
    },
    {
      "surface": "image",
      "workflow_mode": "inpaint",
      "workspace_app": "reference",
      "slot": "image.inpaint.model_loader.after",
      "route_states": [
        "available",
        "experimental_available"
      ]
    },
    {
      "surface": "image",
      "workflow_mode": "outpaint",
      "workspace_app": "reference",
      "slot": "image.outpaint.model_loader.after",
      "route_states": [
        "available",
        "experimental_available"
      ]
    },
    {
      "surface": "image",
      "workflow_mode": null,
      "workspace_app": "generations",
      "slot": "image.parameters.family_loader.after",
      "route_states": [
        "available",
        "experimental_available"
      ]
    }
  ],
  "route_states": {
    "generate": "available",
    "img2img": "available",
    "inpaint": "available",
    "outpaint": "experimental_available"
  }
}
