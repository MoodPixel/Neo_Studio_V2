        "gguf_vae"
      ],
      "readiness_gates": {
        "generate": [
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "img2img": [
          "source_image",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "edit": [
          "source_image",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "outpaint": [
          "source_image",
          "outpaint_padding",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ],
        "inpaint": [
          "source_image",
          "qwen_mmproj",
          "gguf_unet",
          "gguf_text_encoder_primary"
        ]
      },
      "params": [
