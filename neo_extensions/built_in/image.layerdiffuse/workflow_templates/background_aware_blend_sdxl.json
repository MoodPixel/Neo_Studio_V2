{
  "template_schema_version": "layerdiffuse-template-v2",
  "extension_id": "image.layerdiffuse",
  "mode": "background_aware_blend",
  "strategy": "replace_workflow",
  "template_id": "background_aware_blend_sdxl.json",
  "engine": "comfyui",
  "status": "verified_executable",
  "description": "Blend foreground onto the requested background using LayerDiffuse foreground harmonization plus a final Comfy ImageCompositeMasked node.",
  "model_family": [
    "sdxl"
  ],
  "batch_policy": "force_1",
  "required_nodes": [
    "LayeredDiffusionCondApply",
    "LayeredDiffusionDecode",
    "ImageCompositeMasked"
  ],
  "inputs": {
    "required": [
      "prompt",
      "model",
      "foreground_image_id",
      "background_image_id"
    ],
    "optional": [
      "negative_prompt",
      "seed",
      "steps",
      "cfg",
      "sampler",
      "scheduler",
      "width",
      "height"
    ],
    "source_policy": "image",
    "context_policy": [
      "prompt",
      "model",
      "image",
      "metadata"
    ]
  },
  "bindings": {
    "prompt": "$context.prompt",
    "negative_prompt": "$context.negative_prompt",
    "model": "$context.model",
    "seed": "$context.seed",
    "steps": "$context.steps",
    "cfg": "$context.cfg",
    "sampler": "$context.sampler",
    "scheduler": "$context.scheduler",
    "source_image": "$extensions.image.layerdiffuse.raw_state.source_image_id",
    "background_image": "$extensions.image.layerdiffuse.raw_state.background_image_id",
    "foreground_image": "$extensions.image.layerdiffuse.raw_state.foreground_image_id",
    "decode_mode": "preview_only",
    "output_policy": "$extensions.image.layerdiffuse.raw_state.output_policy"
  },
  "outputs": [
    {
      "type": "blended_image",
      "role": "primary",
      "required": true,
      "binding": "$graph.output.blended"
    },
    {
      "type": "preview_image",
      "role": "preview",
      "required": true,
      "binding": "$graph.output.preview"
    }
  ],
  "validation": {
    "block_if_missing_nodes": true,
    "block_if_missing_template": true,
    "block_if_missing_inputs": [
      "prompt",
      "model",
      "foreground_image_id",
      "background_image_id"
    ],
    "force_batch_size": 1,
    "block_replace_without_target": true,
    "warnings": [],
    "phase12_note": "Prompt-driven RGBA templates are synced. Background/composite templates remain blocked until separate verified ComfyUI exports are tested.",
    "phase_c_note": "Neo V2 Phase C includes executable graph wiring for this mode using stable upstream LayerDiffuse node signatures.",
    "phase_k_note": "Phase K wires the loaded background into the final output through ImageCompositeMasked; background is no longer debug-only."
  },
  "graph": {
    "format": "comfyui_api_prompt",
    "status": "verified_executable",
    "node_intent": [
      "Load foreground image",
      "Generate/harmonize foreground with LayerDiffuse",
      "Decode harmonized foreground + alpha mask",
      "Load requested background image",
      "Composite foreground over background with ImageCompositeMasked",
      "Save composite preview/new run/append based on output policy"
    ],
    "placeholders": {
      "checkpoint_loader": "$context.model_loader_node",
      "positive_conditioning": "$context.prompt_conditioning",
      "negative_conditioning": "$context.negative_conditioning",
      "sampler": "$context.sampler_node",
      "layerdiffuse_apply": "LayeredDiffusion*Apply selected by mode",
      "layerdiffuse_decode": "LayeredDiffusionDecodeRGBA or LayeredDiffusionDecodeSplit",
      "save_outputs": "Neo extension output collector",
      "background_compositor": "ImageCompositeMasked destination=background, source=LayerDiffuse foreground, mask=foreground alpha through InvertMask",
      "foreground_alpha_mask": "LoadImage foreground mask -> InvertMask -> ImageCompositeMasked mask"
    },
    "nodes": {
      "1": {
        "class_type": "LoadImage",
        "inputs": {
          "role": "foreground"
        }
      },
      "2": {
        "class_type": "VAEEncode",
        "inputs": {}
      },
      "3": {
        "class_type": "LayeredDiffusionCondApply",
        "inputs": {}
      },
      "4": {
        "class_type": "LayeredDiffusionDecode",
        "inputs": {}
      },
      "5": {
        "class_type": "LoadImage",
        "inputs": {
          "role": "background"
        }
      },
      "6": {
        "class_type": "ImageCompositeMasked",
        "inputs": {}
      },
      "7": {
        "class_type": "SaveImage",
        "inputs": {}
      },
      "8": {
        "class_type": "InvertMask",
        "inputs": {
          "mask": "foreground alpha mask from LoadImage"
        }
      }
    },
    "primary_output": {
      "node_id": "11",
      "source_node_id": "15"
    }
  },
  "notes": [
    "Phase L: background-aware blend saves only compositor outputs; foreground debug SaveImage removed to prevent UI/result hijack.",
    "Phase M: Background-Aware Blend uses the uploaded foreground alpha mask through InvertMask for the final compositor, instead of LayeredDiffusionDecode mask output."
  ]
}