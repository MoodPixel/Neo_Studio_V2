  "ui_schema": {
    "phase": "E.1",
    "route_aware": true,
    "display_modes": [
      "compact",
      "guided",
      "expert"
    ],
    "normal_ui_hidden_states": [
      "planned_gated",
      "provider_gated",
      "unsupported"
    ],
    "diagnostic_visible_states": [
      "planned_gated",
      "provider_gated"
    ],
    "disabled_states": [
      "planned_gated",
      "provider_gated",
      "unsupported"
    ],
    "panels": [
      "embeddings_panel"
    ],
    "fields": [
      {
        "id": "enabled",
        "label": "Enable Embeddings/TI",
        "compact_label": "TI",
        "type": "checkbox",
        "default": false,
        "payload_path": "extensions.embeddings_ti.enabled"
      },
      {
        "id": "scan_folder",
        "label": "Embeddings Folder",
        "type": "path",
        "help_text": "Folder scanned for .pt, .safetensors, and .bin textual inversion files. Provider catalogs may also populate the dropdown when available.",
        "payload_path": "extensions.embeddings_ti.inputs.scan_folder"
      },
      {
        "id": "library_query",
        "label": "Search Embeddings",
        "compact_label": "Search",
        "type": "search",
        "payload_path": "extensions.embeddings_ti.inputs.library_query"
      },
      {
        "id": "selected_embedding",
        "label": "Embedding",
        "type": "select",
        "payload_path": "extensions.embeddings_ti.assets.selected_embedding"
      },
      {
        "id": "selected_embedding_token",
        "label": "Prompt Token",
        "compact_label": "Token",
        "type": "text",
        "payload_path": "extensions.embeddings_ti.assets.selected_embedding.token"
      },
      {
        "id": "target",
        "label": "Target Prompt",
        "type": "select",
        "options": [
          "positive_prompt",
          "negative_prompt",
          "finish_positive",
          "finish_negative"
        ],
        "default": "negative_prompt",
        "payload_path": "extensions.embeddings_ti.params.items[].target"
      },
      {
        "id": "strength",
        "label": "Strength",
        "type": "number",
        "min": 0,
        "max": 2,
        "step": 0.05,
        "default": 1,
        "payload_path": "extensions.embeddings_ti.params.items[].strength"
      },
      {
        "id": "items",
        "label": "Applied Embedding Chips",
        "compact_label": "Chips",
        "type": "array",
        "payload_path": "extensions.embeddings_ti.params.items"
      },
      {
        "id": "civitai_url",
        "label": "CivitAI Link",
        "type": "url",
        "payload_path": "extensions.embeddings_ti.metadata.civitai_url"
      },
      {
        "id": "civitai_pull",
        "label": "Pull from CivitAI",
        "type": "button",
        "payload_path": "extensions.embeddings_ti.actions.civitai_pull"
      }
    ],
    "phase_c_features": [
      "LoRA Stack style built-in Assets mount declaration",
      "extension-local asset bundle declaration",
      "extension-local backend entrypoint declaration",
      "non-node-based prompt asset requirements",
      "route-aware visible/disabled state policy",
      "payload/output/memory contracts aligned with extension runtime",
      "no workflow graph mutation in Phase C"
    ],
    "phase_e_features": [
      "specialized built-in Assets panel rendered by neo_app/static/js/neo.js",
      "route-aware visibility and disabled/gated states",
      "folder/search/provider embedding dropdown controls",
      "LoRA-style chip behavior for applied embedding tokens",
      "positive/negative target prompt selector with finish targets reserved for expert mode",
      "strength control using Comfy prompt-token weighting syntax",
      "CivitAI Textual Inversion pull entry point aligned with LoRA library UX",
      "selected embedding metadata and preview shell",
      "expert payload preview",
      "clean extension payload preview with no active payload on gated routes",
      "no workflow graph mutation in Phase E.1",
      "Phase F payload preview emits canonical items-only contract"
    ]
  },
  "payload_contract": {
    "schema_version": "neo.extension.payload.v1",
    "block_key": "extensions",
    "required_keys": [
      "enabled",
      "version",
      "inputs",
      "params",
      "assets",
      "metadata"
    ],
    "forbids_hidden_field_leakage": true,
    "route_validation_required": true,
    "phase": "G",
    "extension_block_shape": {
      "enabled": "bool",
      "version": "int",
      "inputs": "dict",
      "params": "dict with items[] chip records",
      "assets": "dict",
      "metadata": "dict"
    },
    "active_route_states": [
      "available",
      "experimental_available"
    ],
    "disabled_route_states": [
      "planned_gated",
      "provider_gated",
      "unsupported"
    ],
    "example": {
      "extensions": {
        "embeddings_ti": {
          "enabled": true,
          "version": 1,
          "inputs": {},
          "params": {
            "items": [
              {
                "token": "embedding:EasyNegative",
                "name": "EasyNegative",
                "strength": 1,
                "target": "negative_prompt"
              }
            ]
          },
          "assets": {
            "selected_embeddings": [
              {
                "token": "embedding:EasyNegative",
                "name": "EasyNegative",
                "target": "negative_prompt",
                "strength": 1
              }
            ]
          },
          "metadata": {
            "source": "image.assets.embeddings_ti"
          }
        }
      }
    },
    "allowed_params": [
      "items"
    ],
    "legacy_accepted_params": [
      "selected_tokens",
      "helper_target",
      "base_positive",
      "base_negative",
      "finish_positive",
      "finish_negative"
    ],
    "active_params": [
      "items"
    ],
    "inputs_policy": "always_empty",
    "params_policy": "items_only_after_legacy_migration",
    "asset_policy": "selected_embeddings_metadata_only",
    "hidden_field_policy": "strip_from_clean_block_and_report_in_validation",
    "disabled_behavior": "no_active_params_no_assets_no_workflow_mutation",
    "allowed_item_keys": [
      "uid",
      "id",
      "source_record_id",
      "token",
      "name",
      "strength",
      "target"
    ],
    "validation_phase": "I"
  },
  "memory_contract": {
    "event_type": "extension_workflow_used",
    "namespace_pattern": "extension:{extension_id}",
    "assistant_summary_required": true,
    "record_route": true,
    "record_assets": true,
    "record_params": true,
    "phase": "J",
    "schema_version": "neo.embeddings_ti.memory_event.v1",
    "record_embedding_tokens": true,
    "record_target_groups": true,
    "restore_policy": "revalidate_before_enable",
    "revalidation_required": true
  },
  "output_contract": {
    "metadata_slots": [
      "extensions.used",
      "extensions.payloads",
      "extensions.workflow_patches",
      "extensions.validation",
      "extensions.assistant_summaries",
      "extensions.replay_payloads",
      "extensions.memory_events"
    ],
    "record_input_assets": true,
    "record_route_snapshot": true,
    "record_replay_payload": true,
    "inspector_summary_fields": [
      "enabled",
      "items",
      "target",
      "strength",
      "route_state",
      "gated_reason"
    ],
    "phase": "J",
    "record_assistant_summary": true,
    "record_memory_event": true,
    "record_embedding_tokens": true,
    "replay_restore_policy": "revalidate_before_enable"
  },
  "memory_policy": {
    "phase": "J",
    "assistant_features": "not_implemented",
    "event_shape_prepared": true,
    "event_shape": "extension_workflow_used",
    "schema_version": "neo.embeddings_ti.memory_event.v1",
    "restore_policy": "revalidate_before_enable"
  },
  "output_policy": {
    "phase": "J",
    "inspector_summary_prepared": true,
    "workflow_mutation": "prompt_text_only",
