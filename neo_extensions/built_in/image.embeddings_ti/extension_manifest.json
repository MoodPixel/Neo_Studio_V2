{
  "id": "embeddings_ti",
  "name": "Embeddings / Textual Inversion",
  "version": "0.1.0",
  "description": "Built-in Image Assets extension for Embeddings and Textual Inversion discovery, prompt insertion, metadata capture, and replay-aware prompt composition.",
  "extension_type": "workflow_extension",
  "extension_origin": "built_in",
  "surface": "image",
  "subtabs": [
    "generate",
    "img2img",
    "inpaint",
    "outpaint"
  ],
  "workflow_modes": [
    "generate",
    "img2img",
    "inpaint",
    "outpaint"
  ],
  "workspace_apps": [
    "assets"
  ],
  "mount_slots": [
    "image.assets.embeddings_ti"
  ],
  "mount_targets": [
    {
      "surface": "image",
      "workspace_app": "assets",
      "workflow_mode": null,
      "slot": "image.assets.embeddings_ti",
      "route_states": [
        "available",
        "experimental_available"
      ]
    }
  ],
  "supported_backends": [
    "comfyui",
    "comfyui_portable"
  ],
  "supported_families": [
    "sdxl",
    "sd15",
    "flux",
    "qwen_image",
    "qwen_image_edit_2509",
    "qwen_rapid_aio",
    "z_image",
    "z_image_turbo",
    "hidream",
    "wan_image",
    "hunyuan_image"
  ],
  "supported_loaders": [
    "checkpoint",
    "diffusion_model",
    "unet",
    "gguf"
  ],
  "depends_on": [],
  "extends": [],
  "required_nodes": {
    "comfyui": [],
    "comfyui_portable": []
  },
  "node_requirements": {
    "required": [],
    "optional": [],
    "source": "non_node_based_prompt_asset",
    "notes": [
      "Embeddings/TI is treated as a prompt asset and prompt-token patch extension, not a custom-node extension.",
      "No custom Comfy node is required for the Phase C manifest contract.",
      "Route support is gated by text-encoder/prompt-token compatibility rather than node discovery.",
      "Modern diffusion/GGUF families remain planned-gated until a compatible textual inversion path is validated; no family fallback is allowed."
    ]
  },
